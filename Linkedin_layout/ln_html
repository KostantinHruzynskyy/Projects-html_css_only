<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LinkedIn Clone</title>

    <link rel="stylesheet" href="style.css">

    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>

<header class="navbar">

    <div class="nav-left">

        <div class="logo">in</div>

        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Search">
        </div>

    </div>

    <div class="nav-center">

        <a href="#">
            <i class="fas fa-home"></i>
            <span>Home</span>
        </a>

        <a href="#">
            <i class="fas fa-user-group"></i>
            <span>Network</span>
        </a>

        <a href="#">
            <i class="fas fa-briefcase"></i>
            <span>Jobs</span>
        </a>

        <a href="#">
            <i class="fas fa-message"></i>
            <span>Messages</span>
        </a>

        <a href="#">
            <i class="fas fa-bell"></i>
            <span>Notifications</span>
        </a>

    </div>

    <div class="nav-right">
        <img src="https://picsum.photos/seed/me/100/100" alt="">
    </div>

</header>

<div class="container">

    <!-- LEFT SIDEBAR -->

    <aside class="left-sidebar">

        <div class="left-card">

            <div class="cover"></div>

            <img
            class="profile-pic"
            src="https://picsum.photos/seed/profile/200/200"
            alt="">

            <div class="profile-info">

                <h3>John Doe</h3>

                <p>Frontend Developer</p>

                <p>Turin, Italy</p>

                <div class="stats">

                    <div class="stat">
                        <span>Profile Views</span>
                        <strong>1,543</strong>
                    </div>

                    <div class="stat">
                        <span>Connections</span>
                        <strong>500+</strong>
                    </div>

                </div>

            </div>

        </div>

        <div class="premium">
            <h4>Grow your career</h4>
            <p>Try Premium for free.</p>
        </div>

    </aside>

    <!-- FEED -->

    <main>

        <div class="feed-card">

            <div class="post-start">

                <img
                src="https://picsum.photos/seed/me/100/100"
                alt="">

                <input
                type="text"
                placeholder="Start a post">

            </div>

            <div class="post-options">

                <button><i class="fas fa-image"></i> Photo</button>

                <button><i class="fas fa-video"></i> Video</button>

                <button><i class="fas fa-calendar"></i> Event</button>

                <button><i class="fas fa-newspaper"></i> Article</button>

            </div>

        </div>

        <!-- POST 1 -->

        <div class="post">

            <div class="post-header">

                <img
                src="https://picsum.photos/seed/user1/100/100"
                alt="">

                <div>
                    <h4>Sarah Johnson</h4>
                    <span>UI/UX Designer</span>
                </div>

            </div>

            <div class="post-content">
                Excited to share my latest dashboard design concept.
                Feedback and suggestions are welcome!
            </div>

            <img
            class="post-image"
            src="https://picsum.photos/seed/post1/900/500"
            alt="">

            <div class="post-footer">

                <div class="reactions">
                    👍 1,254 Likes · 💬 78 Comments
                </div>

                <div class="actions">
                    <button>Like</button>
                    <button>Comment</button>
                    <button>Share</button>
                    <button>Send</button>
                </div>

            </div>

        </div>

        <!-- POST 2 -->

        <div class="post">

            <div class="post-header">

                <img
                src="https://picsum.photos/seed/user2/100/100"
                alt="">

                <div>
                    <h4>Michael Brown</h4>
                    <span>Software Engineer</span>
                </div>

            </div>

            <div class="post-content">
                Just completed a full-stack application using
                React, Node.js and PostgreSQL.
            </div>

            <img
            class="post-image"
            src="https://picsum.photos/seed/post2/900/500"
            alt="">

            <div class="post-footer">

                <div class="reactions">
                    👍 876 Likes · 💬 42 Comments
                </div>

                <div class="actions">
                    <button>Like</button>
                    <button>Comment</button>
                    <button>Share</button>
                    <button>Send</button>
                </div>

            </div>

        </div>

    </main>

    <!-- RIGHT SIDEBAR -->

    <aside class="right-sidebar">

        <div class="right-card">

            <h3>LinkedIn News</h3>

            <div class="news-item">
                <strong>AI hiring surges globally</strong>
                <p>4h ago • 2,453 readers</p>
            </div>

            <div class="news-item">
                <strong>Remote jobs continue growth</strong>
                <p>8h ago • 1,822 readers</p>
            </div>

            <div class="news-item">
                <strong>Frontend skills in demand</strong>
                <p>12h ago • 1,091 readers</p>
            </div>

        </div>

    </aside>

</div>

</body>
</html>
